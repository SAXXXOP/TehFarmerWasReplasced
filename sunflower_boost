# sunflower_boost

POWER_MIN = 200
POWER_TARGET_DELTA = 200   # いまのベンチ結果ベスト
WIDTH = 4
HEIGHT = 4
MIN_HARVESTABLE = 9        # いまのベンチ結果ベスト


def go_top_left():
	while get_pos_x() != 0:
		move(West)
	while get_pos_y() != 0:
		move(South)


def clear_rect(width, height):
	go_top_left()
	y = 0
	while y < height:
		if y % 2 == 0:
			x = 0
			while x < width:
				clear()
				if x < width - 1:
					move(East)
				x += 1
		else:
			x = width - 1
			while x >= 0:
				clear()
				if x > 0:
					move(West)
				x -= 1
		if y < height - 1:
			move(North)
		y += 1


def ensure_soil():
	if get_ground_type() != Grounds.Soil:
		till()


def can_afford_sunflower():
	cost = get_cost(Entities.Sunflower)
	if cost == None:
		return True
	for item in cost:
		if num_items(item) < cost[item]:
			return False
	return True


def can_run():
	# main 側で should_refill とセットで使う前提
	return can_afford_sunflower()


def plant_sunflower_rect(width, height):
	go_top_left()
	y = 0
	while y < height:
		if y % 2 == 0:
			x = 0
			while x < width:
				ensure_soil()
				if can_afford_sunflower():
					plant(Entities.Sunflower)
				if x < width - 1:
					move(East)
				x += 1
		else:
			x = width - 1
			while x >= 0:
				ensure_soil()
				if can_afford_sunflower():
					plant(Entities.Sunflower)
				if x > 0:
					move(West)
				x -= 1
		if y < height - 1:
			move(North)
		y += 1


def scan_harvestable_and_best(width, height):
	go_top_left()
	count = 0
	best = -1

	y = 0
	while y < height:
		if y % 2 == 0:
			x = 0
			while x < width:
				if can_harvest():
					count += 1
					v = measure()
					if v != None and v > best:
						best = v
				if x < width - 1:
					move(East)
				x += 1
		else:
			x = width - 1
			while x >= 0:
				if can_harvest():
					count += 1
					v = measure()
					if v != None and v > best:
						best = v
				if x > 0:
					move(West)
				x -= 1
		if y < height - 1:
			move(North)
		y += 1

	return count, best


def harvest_best_and_replant(width, height, best):
	go_top_left()
	y = 0
	while y < height:
		if y % 2 == 0:
			x = 0
			while x < width:
				if can_harvest():
					v = measure()
					if v != None and v == best:
						harvest()
						if can_afford_sunflower():
							plant(Entities.Sunflower)
				if x < width - 1:
					move(East)
				x += 1
		else:
			x = width - 1
			while x >= 0:
				if can_harvest():
					v = measure()
					if v != None and v == best:
						harvest()
						if can_afford_sunflower():
							plant(Entities.Sunflower)
				if x > 0:
					move(West)
				x -= 1
		if y < height - 1:
			move(North)
		y += 1


def should_refill():
	return num_items(Items.Power) < POWER_MIN


def run():
	start_power = num_items(Items.Power)
	target_power = start_power + POWER_TARGET_DELTA

	# 対象区画だけ初期化
	clear_rect(WIDTH, HEIGHT)
	plant_sunflower_rect(WIDTH, HEIGHT)

	while num_items(Items.Power) < target_power:
		harv, best = scan_harvestable_and_best(WIDTH, HEIGHT)
		if harv >= MIN_HARVESTABLE and best != -1:
			harvest_best_and_replant(WIDTH, HEIGHT, best)
