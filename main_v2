# main_v2
# mode_selector を切り出した版

import goal
import mode_selector
import dinosaur_boost
import hay_mode_v2
import wood_mode_v2
import carrot_mode_v2_rect_fertilizer
import pumpkin_mode_v2
import cactus_mode_v2

def is_empty_cost(cost):
	if cost == None:
		return True

	for item in cost:
		return False

	return True

def ensure_normal_hat():
	change_hat(Hats.Straw_Hat)

def get_missing_map(cost):
	missing = {}

	if is_empty_cost(cost):
		return missing

	for item in cost:
		diff = cost[item] - num_items(item)
		if diff > 0:
			missing[item] = diff

	return missing

def print_goal_status(target_info):
	quick_print("goal mode =", target_info["goal_mode"])
	quick_print("target =", target_info["target"])
	quick_print("target level =", target_info["target_level"])
	quick_print("cost =", target_info["cost"])

	print("goal mode =", target_info["goal_mode"])
	print("target =", target_info["target"])
	print("target level =", target_info["target_level"])
	print("cost =", target_info["cost"])

def print_missing_status(target_info):
	cost = target_info["cost"]

	if is_empty_cost(cost):
		quick_print("missing = none")
		return

	missing = get_missing_map(cost)

	empty = True
	for item in missing:
		empty = False
		quick_print(item, "need", cost[item], "have", num_items(item), "missing", missing[item])

	if empty:
		quick_print("missing = none")

def try_unlock_target(target_info):
	target = target_info["target"]
	cost = target_info["cost"]
	level = target_info["target_level"]

	if target == None:
		return False

	if is_empty_cost(cost):
		return False

	for item in cost:
		if num_items(item) < cost[item]:
			return False

	if level == None:
		unlock(target)
	else:
		unlock(target, level)

	return True

target_info = goal.resolve_target()
print_goal_status(target_info)
print_missing_status(target_info)

while True:
	target_info = goal.resolve_target()

	if try_unlock_target(target_info):
		quick_print("unlocked =", target_info["target"])
		target_info = goal.resolve_target()
		print_goal_status(target_info)
		print_missing_status(target_info)

	mode = mode_selector.choose_mode_for_target(target_info)
	quick_print("mode =", mode)

	if mode == "hay":
		ensure_normal_hat()
		hay_mode_v2.run()

	elif mode == "wood":
		ensure_normal_hat()
		wood_mode_v2.run()

	elif mode == "carrot":
		ensure_normal_hat()
		carrot_mode_v2_rect_fertilizer.run()

	elif mode == "pumpkin":
		ensure_normal_hat()
		gained = pumpkin_mode_v2.run()
		if gained > 0:
			quick_print("pumpkin gained =", gained)

	elif mode == "cactus":
		ensure_normal_hat()
		gained = cactus_mode_v2.run()
		if gained > 0:
			quick_print("cactus gained =", gained)

	elif mode == "bone":
		target_cost = target_info["cost"]
		target_bones = target_cost[Items.Bone]
		quick_print("bone target =", target_bones, "have =", num_items(Items.Bone))
		dinosaur_boost.run(target_bones)

	else:
		ensure_normal_hat()
		quick_print("mode = idle")
