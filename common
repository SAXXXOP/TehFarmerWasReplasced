def go_top_left():
	while get_pos_x() != 0:
		move(East)
	while get_pos_y() != 0:
		move(North)

def ensure_grass():
	if get_ground_type() != Grounds.Grassland:
		till()

def ensure_soil():
	if get_ground_type() != Grounds.Soil:
		till()

def water_if_needed():
	if get_water() < 0.5:
		if num_items(Items.Water) > 0:
			use_item(Items.Water)
