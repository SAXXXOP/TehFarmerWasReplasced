# sunflower_mode_v2
# 左上 4x4 でひまわりを育てて、power が目標に達するまで回す
# ネスト関数 / global を使わない安全版

import field_utils

AREA_SIZE = 4

def go_rect_top_left():
	field_utils.go_top_left()

def plant_rect():
	go_rect_top_left()

	y = 0
	while y < AREA_SIZE:
		if y % 2 == 0:
			x = 0
			while x < AREA_SIZE:
				if get_entity_type() != Entities.Sunflower:
					if can_harvest():
						harvest()
					else:
						clear()
					plant(Entities.Sunflower)

				if x < AREA_SIZE - 1:
					move(East)
				x += 1
		else:
			x = AREA_SIZE - 1
			while x >= 0:
				if get_entity_type() != Entities.Sunflower:
					if can_harvest():
						harvest()
					else:
						clear()
					plant(Entities.Sunflower)

				if x > 0:
					move(West)
				x -= 1

		if y < AREA_SIZE - 1:
			move(South)
		y += 1

def all_sunflowers_harvestable():
	go_rect_top_left()

	y = 0
	while y < AREA_SIZE:
		if y % 2 == 0:
			x = 0
			while x < AREA_SIZE:
				if get_entity_type() != Entities.Sunflower:
					return False
				if not can_harvest():
					return False

				if x < AREA_SIZE - 1:
					move(East)
				x += 1
		else:
			x = AREA_SIZE - 1
			while x >= 0:
				if get_entity_type() != Entities.Sunflower:
					return False
				if not can_harvest():
					return False

				if x > 0:
					move(West)
				x -= 1

		if y < AREA_SIZE - 1:
			move(South)
		y += 1

	return True

def find_best_petals():
	best = -1
	best_x = 0
	best_y = 0

	go_rect_top_left()

	y = 0
	while y < AREA_SIZE:
		if y % 2 == 0:
			x = 0
			while x < AREA_SIZE:
				if get_entity_type() == Entities.Sunflower and can_harvest():
					p = measure()
					if p != None and p > best:
						best = p
						best_x = get_pos_x()
						best_y = get_pos_y()

				if x < AREA_SIZE - 1:
					move(East)
				x += 1
		else:
			x = AREA_SIZE - 1
			while x >= 0:
				if get_entity_type() == Entities.Sunflower and can_harvest():
					p = measure()
					if p != None and p > best:
						best = p
						best_x = get_pos_x()
						best_y = get_pos_y()

				if x > 0:
					move(West)
				x -= 1

		if y < AREA_SIZE - 1:
			move(South)
		y += 1

	return best, best_x, best_y

def run(target_power):
	while num_items(Items.Power) < target_power:
		plant_rect()

		if not all_sunflowers_harvestable():
			continue

		best, x, y = find_best_petals()

		field_utils.go_to(x, y)
		if get_entity_type() == Entities.Sunflower and can_harvest():
			harvest()

	return True
