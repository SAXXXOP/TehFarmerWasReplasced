# main

import goal
import sunflower_boost
import dinosaur_boost
import hay_mode
import wood_mode
import carrot_mode

def is_empty_cost(cost):
	if cost == None:
		return True

	for item in cost:
		return False

	return True

def ensure_normal_hat():
	change_hat(Hats.Straw_Hat)
	
def go_top_left():
	while get_pos_x() != 0:
		move(West)
	while get_pos_y() != 0:
		move(South)

def ensure_soil():
	if get_ground_type() != Grounds.Soil:
		till()

def reset_and_plant_cactus_square(size):
	go_top_left()

	y = 0
	while y < size:
		if y % 2 == 0:
			x = 0
			while x < size:
				clear()
				ensure_soil()
				plant(Entities.Cactus)

				if x < size - 1:
					move(East)
				x += 1
		else:
			x = size - 1
			while x >= 0:
				clear()
				ensure_soil()
				plant(Entities.Cactus)

				if x > 0:
					move(West)
				x -= 1

		if y < size - 1:
			move(North)
		y += 1

def plant_pumpkin_tile():
	ensure_soil()
	plant(Entities.Pumpkin)

def all_grown_square(size):
	go_top_left()

	y = 0
	while y < size:
		if y % 2 == 0:
			x = 0
			while x < size:
				if not can_harvest():
					return False

				if x < size - 1:
					move(East)
				x += 1
		else:
			x = size - 1
			while x >= 0:
				if not can_harvest():
					return False

				if x > 0:
					move(West)
				x -= 1

		if y < size - 1:
			move(North)
		y += 1

	return True

def move_to(x, y):
	cx = get_pos_x()
	cy = get_pos_y()

	while cx < x:
		move(East)
		cx += 1

	while cx > x:
		move(West)
		cx -= 1

	while cy < y:
		move(North)
		cy += 1

	while cy > y:
		move(South)
		cy -= 1

def sweep_sort_cactus(size, passes):
	p = 0
	while p < passes:
		go_top_left()

		y = 0
		while y < size:
			if y % 2 == 0:
				x = 0
				while x < size:
					cur = measure()

					if x < size - 1:
						east = measure(East)
						if cur > east:
							swap(East)

					if y < size - 1:
						cur = measure()
						north = measure(North)
						if cur > north:
							swap(North)

					if x < size - 1:
						move(East)
					x += 1
			else:
				x = size - 1
				while x >= 0:
					cur = measure()

					if x > 0:
						west = measure(West)
						if west > cur:
							swap(West)

					if y < size - 1:
						cur = measure()
						north = measure(North)
						if cur > north:
							swap(North)

					if x > 0:
						move(West)
					x -= 1

			if y < size - 1:
				move(North)
			y += 1

		p += 1

def sort_row_left_to_right(y, size):
	move_to(0, y)

	x = 0
	while x < size - 1:
		cur_value = measure()
		east_value = measure(East)

		if cur_value > east_value:
			swap(East)

		if x < size - 2:
			move(East)
		x += 1

def sort_row_right_to_left(y, size):
	move_to(size - 1, y)

	x = size - 1
	while x > 0:
		cur_value = measure()
		west_value = measure(West)

		if west_value > cur_value:
			swap(West)

		if x > 1:
			move(West)
		x -= 1

def sort_col_bottom_to_top(x, size):
	move_to(x, 0)

	y = 0
	while y < size - 1:
		cur_value = measure()
		north_value = measure(North)

		if cur_value > north_value:
			swap(North)

		if y < size - 2:
			move(North)
		y += 1

def sort_col_top_to_bottom(x, size):
	move_to(x, size - 1)

	y = size - 1
	while y > 0:
		cur_value = measure()
		south_value = measure(South)

		if south_value > cur_value:
			swap(South)

		if y > 1:
			move(South)
		y -= 1

def refine_sort_cactus(size, passes):
	p = 0
	while p < passes:
		y = 0
		while y < size:
			sort_row_left_to_right(y, size)
			y += 1

		x = 0
		while x < size:
			sort_col_bottom_to_top(x, size)
			x += 1

		y = size - 1
		while y >= 0:
			sort_row_right_to_left(y, size)
			y -= 1

		x = size - 1
		while x >= 0:
			sort_col_top_to_bottom(x, size)
			x -= 1

		p += 1

def hybrid_sort_cactus(size, sweep_passes, refine_passes):
	sweep_sort_cactus(size, sweep_passes)
	refine_sort_cactus(size, refine_passes)

def harvest_cactus_one(size):
	go_top_left()

	x = 0
	while x < size - 1:
		move(East)
		x += 1

	y = 0
	while y < size - 1:
		move(North)
		y += 1

	before = num_items(Items.Cactus)
	harvest()
	after = num_items(Items.Cactus)
	return after - before

def run_cactus():
	size = get_world_size()
	sweep_passes = 5
	refine_passes = 2

	reset_and_plant_cactus_square(size)

	while True:
		if all_grown_square(size):
			hybrid_sort_cactus(size, sweep_passes, refine_passes)
			return harvest_cactus_one(size)

def enough_for_pumpkin_mode():
	if num_items(Items.Hay) < 2500:
		return False
	if num_items(Items.Wood) < 2500:
		return False
	if num_items(Items.Carrot) < 1200:
		return False
	return True

def maintain_pumpkin_field():
	go_top_left()
	size = get_world_size()

	y = 0
	while y < size:
		if y % 2 == 0:
			x = 0
			while x < size:
				plant_pumpkin_tile()

				if x < size - 1:
					move(East)
				x += 1
		else:
			x = size - 1
			while x >= 0:
				plant_pumpkin_tile()

				if x > 0:
					move(West)
				x -= 1

		if y < size - 1:
			move(North)
		y += 1

def harvest_pumpkin_field():
	go_top_left()
	size = get_world_size()

	before = num_items(Items.Pumpkin)

	y = 0
	while y < size:
		if y % 2 == 0:
			x = 0
			while x < size:
				harvest()

				if x < size - 1:
					move(East)
				x += 1
		else:
			x = size - 1
			while x >= 0:
				harvest()

				if x > 0:
					move(West)
				x -= 1

		if y < size - 1:
			move(North)
		y += 1

	after = num_items(Items.Pumpkin)
	return after - before

def run_pumpkin():
	maintain_pumpkin_field()

	if all_grown_square(get_world_size()):
		return harvest_pumpkin_field()

	return 0

def get_missing_map(cost):
	missing = {}

	if is_empty_cost(cost):
		return missing

	for item in cost:
		diff = cost[item] - num_items(item)
		if diff > 0:
			missing[item] = diff

	return missing
	
def print_goal_status(target_info):
	quick_print("goal mode =", target_info["goal_mode"])
	quick_print("target =", target_info["target"])
	quick_print("target level =", target_info["target_level"])
	quick_print("cost =", target_info["cost"])
	
	print("goal mode =", target_info["goal_mode"])
	print("target =", target_info["target"])
	print("target level =", target_info["target_level"])
	print("cost =", target_info["cost"])

def print_missing_status(target_info):
	cost = target_info["cost"]

	if is_empty_cost(cost):
		quick_print("missing = none")
		return

	missing = get_missing_map(cost)

	empty = True
	for item in missing:
		empty = False
		quick_print(item, "need", cost[item], "have", num_items(item), "missing", missing[item])

	if empty:
		quick_print("missing = none")

def choose_mode_for_target(target_info):
	cost = target_info["cost"]

	if is_empty_cost(cost):
		return "idle"

	hay_missing = 0
	wood_missing = 0
	carrot_missing = 0
	pumpkin_missing = 0
	cactus_missing = 0
	bone_missing = 0

	if Items.Hay in cost:
		hay_missing = max(0, cost[Items.Hay] - num_items(Items.Hay))

	if Items.Wood in cost:
		wood_missing = max(0, cost[Items.Wood] - num_items(Items.Wood))

	if Items.Carrot in cost:
		carrot_missing = max(0, cost[Items.Carrot] - num_items(Items.Carrot))

	if Items.Pumpkin in cost:
		pumpkin_missing = max(0, cost[Items.Pumpkin] - num_items(Items.Pumpkin))

	if Items.Cactus in cost:
		cactus_missing = max(0, cost[Items.Cactus] - num_items(Items.Cactus))

	if Items.Bone in cost:
		bone_missing = max(0, cost[Items.Bone] - num_items(Items.Bone))

	if bone_missing > 0:
		return "bone"

	mode = "idle"
	biggest_missing = 0

	if hay_missing > biggest_missing:
		biggest_missing = hay_missing
		mode = "hay"

	if wood_missing > biggest_missing:
		biggest_missing = wood_missing
		mode = "wood"

	if carrot_missing > biggest_missing:
		biggest_missing = carrot_missing
		mode = "carrot"

	if pumpkin_missing > biggest_missing:
		if enough_for_pumpkin_mode():
			biggest_missing = pumpkin_missing
			mode = "pumpkin"
		else:
			# かぼちゃ準備が足りない間は、まず不足素材を作る
			if num_items(Items.Hay) < 2500:
				return "hay"
			if num_items(Items.Wood) < 2500:
				return "wood"
			if num_items(Items.Carrot) < 1200:
				return "carrot"

	if cactus_missing > biggest_missing:
		biggest_missing = cactus_missing
		mode = "cactus"

	return mode
	
def try_unlock_target(target_info):
	target = target_info["target"]
	cost = target_info["cost"]
	level = target_info["target_level"]

	if target == None:
		return False

	if is_empty_cost(cost):
		return False

	for item in cost:
		if num_items(item) < cost[item]:
			return False

	if level == None:
		unlock(target)
	else:
		unlock(target, level)

	return True

target_info = goal.resolve_target()
print_goal_status(target_info)
print_missing_status(target_info)

while True:
	target_info = goal.resolve_target()

	if try_unlock_target(target_info):
		quick_print("unlocked =", target_info["target"])
		target_info = goal.resolve_target()
		print_goal_status(target_info)
		print_missing_status(target_info)

	if sunflower_boost.should_refill() and sunflower_boost.can_run():
		quick_print("mode = sunflower_boost")
		sunflower_boost.run()
	else:
		mode = choose_mode_for_target(target_info)
	
		if sunflower_boost.should_refill() and not sunflower_boost.can_run():
			quick_print("sunflower not ready")
	
		quick_print("mode =", mode)
	
		if mode == "hay":
			ensure_normal_hat()
			hay_mode.run()
	
		elif mode == "wood":
			ensure_normal_hat()
			wood_mode.run()
	
		elif mode == "carrot":
			ensure_normal_hat()
			carrot_mode.run()
	
		elif mode == "pumpkin":
			ensure_normal_hat()
			if enough_for_pumpkin_mode():
				gained = run_pumpkin()
				quick_print("pumpkin gained =", gained)
			else:
				quick_print("pumpkin not ready")
	
		elif mode == "cactus":
			ensure_normal_hat()
			gained = run_cactus()
			quick_print("cactus gained =", gained)
	
		elif mode == "bone":
			target_cost = target_info["cost"]
			target_bones = target_cost[Items.Bone]
			quick_print("bone target =", target_bones, "have =", num_items(Items.Bone))
			dinosaur_boost.run(target_bones)
	
		else:
			ensure_normal_hat()
			quick_print("mode = idle")
