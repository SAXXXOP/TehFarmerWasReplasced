# main

import goal
import sunflower_boost
import dinosaur_boost
import hay_mode
import wood_mode
import carrot_mode
import cactus_mode
import pumpkin_mode

def is_empty_cost(cost):
	if cost == None:
		return True

	for item in cost:
		return False

	return True

def ensure_normal_hat():
	change_hat(Hats.Straw_Hat)
	
def go_top_left():
	while get_pos_x() != 0:
		move(West)
	while get_pos_y() != 0:
		move(South)

def ensure_soil():
	if get_ground_type() != Grounds.Soil:
		till()

def get_missing_map(cost):
	missing = {}

	if is_empty_cost(cost):
		return missing

	for item in cost:
		diff = cost[item] - num_items(item)
		if diff > 0:
			missing[item] = diff

	return missing
	
def print_goal_status(target_info):
	quick_print("goal mode =", target_info["goal_mode"])
	quick_print("target =", target_info["target"])
	quick_print("target level =", target_info["target_level"])
	quick_print("cost =", target_info["cost"])
	
	print("goal mode =", target_info["goal_mode"])
	print("target =", target_info["target"])
	print("target level =", target_info["target_level"])
	print("cost =", target_info["cost"])

def print_missing_status(target_info):
	cost = target_info["cost"]

	if is_empty_cost(cost):
		quick_print("missing = none")
		return

	missing = get_missing_map(cost)

	empty = True
	for item in missing:
		empty = False
		quick_print(item, "need", cost[item], "have", num_items(item), "missing", missing[item])

	if empty:
		quick_print("missing = none")

def choose_mode_for_target(target_info):
	cost = target_info["cost"]

	if is_empty_cost(cost):
		return "idle"

	hay_missing = 0
	wood_missing = 0
	carrot_missing = 0
	pumpkin_missing = 0
	cactus_missing = 0
	bone_missing = 0

	if Items.Hay in cost:
		hay_missing = max(0, cost[Items.Hay] - num_items(Items.Hay))

	if Items.Wood in cost:
		wood_missing = max(0, cost[Items.Wood] - num_items(Items.Wood))

	if Items.Carrot in cost:
		carrot_missing = max(0, cost[Items.Carrot] - num_items(Items.Carrot))

	if Items.Pumpkin in cost:
		pumpkin_missing = max(0, cost[Items.Pumpkin] - num_items(Items.Pumpkin))

	if Items.Cactus in cost:
		cactus_missing = max(0, cost[Items.Cactus] - num_items(Items.Cactus))

	if Items.Bone in cost:
		bone_missing = max(0, cost[Items.Bone] - num_items(Items.Bone))

	if bone_missing > 0:
		return "bone"

	mode = "idle"
	biggest_missing = 0

	if hay_missing > biggest_missing:
		biggest_missing = hay_missing
		mode = "hay"

	if wood_missing > biggest_missing:
		biggest_missing = wood_missing
		mode = "wood"

	if carrot_missing > biggest_missing:
		biggest_missing = carrot_missing
		mode = "carrot"

	if pumpkin_missing > biggest_missing:
		if pumpkin_mode.enough_for_mode():
			biggest_missing = pumpkin_missing
			mode = "pumpkin"
		else:
			if num_items(Items.Hay) < 2500:
				return "hay"
			if num_items(Items.Wood) < 2500:
				return "wood"
			if num_items(Items.Carrot) < 1200:
				return "carrot"

	if cactus_missing > biggest_missing:
		biggest_missing = cactus_missing
		mode = "cactus"

	return mode
	
def try_unlock_target(target_info):
	target = target_info["target"]
	cost = target_info["cost"]
	level = target_info["target_level"]

	if target == None:
		return False

	if is_empty_cost(cost):
		return False

	for item in cost:
		if num_items(item) < cost[item]:
			return False

	if level == None:
		unlock(target)
	else:
		unlock(target, level)

	return True

target_info = goal.resolve_target()
print_goal_status(target_info)
print_missing_status(target_info)

last_mode = "idle"
pumpkin_flow_active = False

while True:
	target_info = goal.resolve_target()

	if try_unlock_target(target_info):
		quick_print("unlocked =", target_info["target"])
		target_info = goal.resolve_target()
		print_goal_status(target_info)
		print_missing_status(target_info)

	# 先に必要モードを決める
	mode = choose_mode_for_target(target_info)

	# pumpkin 以外に移ったら、pumpkin セッション終了
	if mode != "pumpkin":
		pumpkin_flow_active = False

	# pumpkin のときは「未開始」の間だけ sunflower を許可
	if mode == "pumpkin":
		allow_sunflower_before_mode = (not pumpkin_flow_active)
	else:
		allow_sunflower_before_mode = True

	if allow_sunflower_before_mode and sunflower_boost.should_refill() and sunflower_boost.can_run():
		quick_print("mode = sunflower_boost")
		sunflower_boost.run()
		last_mode = "sunflower_boost"
	else:
		if mode == "pumpkin" and pumpkin_flow_active and sunflower_boost.should_refill():
			quick_print("sunflower deferred until after pumpkin harvest")

		if sunflower_boost.should_refill() and not sunflower_boost.can_run() and allow_sunflower_before_mode:
			quick_print("sunflower not ready")

		quick_print("mode =", mode)

		next_last_mode = mode

		if mode == "hay":
			ensure_normal_hat()
			hay_mode.run()

		elif mode == "wood":
			ensure_normal_hat()
			wood_mode.run()

		elif mode == "carrot":
			ensure_normal_hat()
			carrot_mode.run()

		elif mode == "pumpkin":
			ensure_normal_hat()
			if pumpkin_mode.enough_for_mode():
				# pumpkin セッションの最初の1回だけ field reset
				reset_field = (not pumpkin_flow_active)
				if reset_field:
					quick_print("pumpkin enter: reset_field=", reset_field, "last_mode=", last_mode)

				# ここから pumpkin セッション開始
				pumpkin_flow_active = True

				gained = pumpkin_mode.run(reset_field)

				if gained > 0:
					quick_print("pumpkin gained =", gained)

					# 最大化して収穫した直後だけ sunflower に入る
					if sunflower_boost.should_refill() and sunflower_boost.can_run():
						quick_print("mode = sunflower_boost (after pumpkin harvest)")
						sunflower_boost.run()
						next_last_mode = "sunflower_boost"
					elif sunflower_boost.should_refill():
						quick_print("sunflower wanted after pumpkin harvest but not ready")
			else:
				quick_print("pumpkin not ready")

		elif mode == "cactus":
			ensure_normal_hat()
			gained = cactus_mode.run()
			quick_print("cactus gained =", gained)

		elif mode == "bone":
			target_cost = target_info["cost"]
			target_bones = target_cost[Items.Bone]
			quick_print("bone target =", target_bones, "have =", num_items(Items.Bone))
			dinosaur_boost.run(target_bones)

		else:
			ensure_normal_hat()
			quick_print("mode = idle")

		last_mode = next_last_mode
